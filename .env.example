PORT=3000

# ── Option A: Supabase / hosted PostgreSQL (preferred for Vercel deployment) ──
# Get this from Supabase → Project Settings → Database → Connection Pooling (port 6543)
DATABASE_URL=postgresql://postgres.[YOUR_PROJECT]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DB_SSL=true

# ── Option B: Local Docker / self-hosted PostgreSQL ──
# Used only when DATABASE_URL is NOT set
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres

# Required: set a strong password — do not leave this blank
DB_PASSWORD=

DB_NAME=github_analyzer

# Optional but recommended: prevents GitHub API rate limiting (60 → 5000 req/hr)
GITHUB_TOKEN=

# Comma-separated list of allowed frontend origins for CORS
ALLOWED_ORIGINS=http://localhost:3000
